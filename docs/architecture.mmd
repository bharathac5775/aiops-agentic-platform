flowchart LR

%% LinkedIn-ready architecture flow for AIOps Agentic Self-Healing Platform

subgraph A[Observability Signals]
  P[Prometheus\nMetrics]
  L[Loki\nLogs]
  AR[Alert Rules\nCPU, Memory, CrashLoop, OOM]
  AM[Alertmanager]
  P --> AR --> AM
  L --> AR
end

subgraph B[AI Engine\nFastAPI + LangGraph]
  API[/POST /alerts/]
  ORCH[Agent Orchestrator]

  subgraph C[Multi-Agent Runtime]
    M[1. Monitor Agent]
    R[2. RCA Agent\nLLM + RAG]
    D[3. Remediation Agent\nPolicy + Guardrails]
    REP[4. Report Agent]
    FB[Fallback Agent]
    M --> R --> D --> REP
    D -. guarded block .-> FB --> REP
  end

  MEM[Chroma Memory\nIncident Similarity]
  OLL[Ollama LLM]
  K8S[Kubernetes Executor\nrestart, scale, rollback]
end

subgraph E[Runtime Outcomes]
  INC[Incident History\nJSONL + Markdown]
  DIS[Discord Notifications]
  DAS[Streamlit Dashboard]
end

subgraph F[Delivery Automation]
  GH[GitHub]
  JN[Jenkins CI/CD]
  IMG[Docker Images]
  DEP[K8s Deploy + Rollout]
  GH --> JN --> IMG --> DEP
end

AM --> API --> ORCH
ORCH --> M
R --> OLL
R --> MEM
D --> K8S
REP --> INC
REP --> DIS
DAS --> INC
DEP --> B

