classDef runtime fill:#F4FDEB,stroke:#4C8A00,stroke-width:1.5px,color:#173300;
classDef out fill:#F8F1FF,stroke:#7A3EB1,stroke-width:1.5px,color:#2B1045;
classDef cicd fill:#F3F4F6,stroke:#4B5563,stroke-width:1.5px,color:#111827;

class P,L,AR,AM src;
class API,ORCH,MEM,OLL,K8S engine;
class M,R,D,REP,FB runtime;
class INC,DIS,DAS out;
class GH,JN,IMG,DEP cicd;
