flowchart TB

T[AIOps Agentic Self-Healing Kubernetes Platform\nEnd-to-End Intelligent Incident Lifecycle]

subgraph TOP[Architecture Flow]
  direction LR

  subgraph OBS[Observability]
    PR[Prometheus\nMetrics]
    LK[Loki\nLogs]
    AR[Alert Rules]
    AM[Alertmanager]
    PR --> AR --> AM
    LK --> AR
  end

  subgraph ENG[AI Engine: FastAPI + LangGraph]
    API[/POST /alerts/]
    ORCH[Agent Orchestrator]
    AG[Monitor -> RCA -> Remediation -> Report]
    MEM[Chroma RAG Memory]
    LLM[Ollama LLM]
    GUA[Policy Guardrails\nconfidence, cooldown, retries]

    API --> ORCH --> AG
    AG --> LLM
    AG --> MEM
    AG --> GUA
  end

  subgraph EXE[Execution and Outcomes]
    K8S[Kubernetes Actions\nrestart, scale, rollback]
    INC[Incident History\nJSONL + Markdown]
    DIS[Discord Notifications]
    DASH[Dashboard Visibility\nStreamlit + Grafana]

    K8S --> INC
    INC --> DIS
    INC --> DASH
  end

  AM --> API
  GUA --> K8S
end

subgraph BOT[Live Runtime Action Flow]
  direction LR
  S1[1 Detect\nAlert Fired] --> S2[2 Analyze\nLLM + RAG RCA]
  S2 --> S3[3 Decide\nGuardrails Check]
  S3 --> S4[4 Remediate\nSafe K8s Action]
  S4 --> S5[5 Persist + Notify\nHistory + Discord]
end

subgraph CICD[Continuous Delivery]
  direction LR
  GH[GitHub] --> JN[Jenkins Pipeline] --> IMG[Docker Images] --> DEP[Kubernetes Rollout]
  DEP --> API
end

T --> TOP
TOP --> BOT
BOT --> CICD

